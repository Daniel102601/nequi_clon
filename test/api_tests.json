      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Verificamos que el servidor responda correctamente (Código HTTP 200)\r",
              "pm.test(\"El servidor responde con status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Verificamos que tu PHP devuelva el JSON esperado\r",
              "pm.test(\"El login es exitoso según la base de datos\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.status).to.eql(\"success\");\r",
              "    pm.expect(jsonData.data).to.have.property(\"id\"); // Verificamos que devuelva un ID\r",
              "});"
            ],
