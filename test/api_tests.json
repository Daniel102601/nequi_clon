  "item": [
    {
      "name": "VERIFICACION LOGIN REAL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El servidor responde con status 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"El login es exitoso según la base de datos\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"success\");",
              "    pm.expect(jsonData.data).to.have.property(\"id\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "telefono",
              "value": "3016872575",
              "type": "text"
            },
            {
              "key": "pin",
              "value": "1026",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "http://localhost/nequi_api/login.php",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "path": [
            "nequi_api",
            "login.php"
          ]
        }
      },
      "response": []
    }
  ]
